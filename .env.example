# Firebase client configuration (SPA — Vite)
# Copy this file to .env.local and fill in the values from the Firebase console
# (Project Settings → Your apps → Web app → SDK snippet → Config).
# .env.local is git-ignored and must never be committed.
#
# These are PUBLIC client-side keys — not secrets. Do NOT store private keys,
# service account credentials or secret tokens here or in any committed file.
#
# When VITE_USE_EMULATORS=true the app connects to local emulators instead of
# Firebase production/dev services. Always set this to true during development.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to route all Firebase calls to local emulators
VITE_USE_EMULATORS=true
