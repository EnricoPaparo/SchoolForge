rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // Checks that the caller's uid matches the ownerUid stored in settings/owner.
    function isOwner() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/settings/owner)
        && request.auth.uid
           == get(/databases/$(database)/documents/settings/owner).data.ownerUid;
    }

    // --- settings/owner ---
    // First authenticated user to write becomes the owner (no existing doc).
    // Subsequent updates/deletes require ownerUid match.
    match /settings/owner {
      allow read: if isOwner();
      allow create: if isAuthenticated()
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isOwner();
    }

    // --- Teacher-owned collections ---
    match /classes/{classId} {
      allow read, update, delete: if isOwner();
      allow create: if isOwner() && request.resource.data.ownerUid == request.auth.uid;
    }

    match /programs/{docId} {
      allow read, write: if isOwner();
    }
    match /programs/{programId}/{sub=**} {
      allow read, write: if isOwner();
    }

    match /verifications/{docId} {
      allow read, delete: if isOwner();
      allow create: if isOwner() && request.resource.data.ownerUid == request.auth.uid;
      // Draft: any owner update allowed.
      // Active: only status transition to 'closed' is permitted.
      // Closed: no updates allowed.
      allow update: if isOwner()
        && (
          resource.data.status == 'draft'
          || (resource.data.status == 'active' && request.resource.data.status == 'closed')
        );
    }
    match /verifications/{verificationId}/{sub=**} {
      // read: owner only; write on sub-collections handled per-path in later milestones.
      // Note: {sub=**} can match the document itself (zero segments), so write is intentionally
      // omitted here — update semantics on /verifications/{docId} are enforced above.
      allow read: if isOwner();
      // TODO M2: publicVerificationLinks readable when verification is active
    }

    match /auditEvents/{docId} {
      allow read, write: if isOwner();
    }

    match /corrections/{docId} {
      allow read, write: if isOwner();
    }
    match /correctionEvents/{docId} {
      allow read, write: if isOwner();
    }

    // deliveryAttempts: owner can read (for corrections/export); writes via Cloud Functions (M3)
    match /deliveryAttempts/{docId} {
      allow read: if isOwner();
      allow write: if false;
    }
    match /deliveryAttempts/{docId}/{sub=**} {
      allow read: if isOwner();
      allow write: if false;
    }

    // --- Default deny ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
